@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Threads)

if(@REGOCPP_USE_FETCH_CONTENT@)
  # Dependencies were fetched at build time and are bundled in the export targets
else()
  # Dependencies are resolved via find_package; caller must have them installed
  find_dependency(trieste CONFIG)

  if("@REGOCPP_CRYPTO_BACKEND@" STREQUAL "openssl3")
    find_dependency(OpenSSL 3.0)
  endif()
endif()

if(NOT TARGET regocpp::rego)
    include("${CMAKE_CURRENT_LIST_DIR}/regocppTargets.cmake")
endif()

set(REGOCPP_LIBRARIES regocpp::rego)